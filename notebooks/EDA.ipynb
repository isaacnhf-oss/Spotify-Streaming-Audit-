   ],
   "source": [
    "# Agrupación de géneros por popularidad\n",
    "genre_popularity = df_spotify_clean.groupby('top_genre').agg(\n",
    "    total_tracks=('popularity', 'count'),\n",
    "    popularity_mean=('popularity', 'mean')\n",
    ").sort_values(by='popularity_mean', ascending=False).head(20)\n",
    "\n",
    "# Gráfico del top 20 de los géneros más populares del catálogo\n",
    "plt.figure(figsize=(10, 6))\n",
    "sns.barplot(data=genre_popularity.reset_index(), x='popularity_mean', y='top_genre', color='#1DB954')\n",
    "plt.title('Top 20 Géneros con mayor popularidad promedio', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Popularidad Promedio')\n",
    "plt.ylabel('Género')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "afea3d6a",
   "metadata": {},
   "source": [
    "El top 20 de los géneros con mayor popularidad promedio está liderado por 'celtic pukn' e 'indie pop', el resto del grupo presenta scores entre los 70 y 80 puntos. "
   ]
  },
  {
