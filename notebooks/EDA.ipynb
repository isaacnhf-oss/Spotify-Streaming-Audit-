  },
  {
   "cell_type": "code",
<<<<<<< HEAD
   "execution_count": null,
   "id": "744de19d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Q1 (25%): 49.2 | Q2 (50%): 62.0 | Q3 (75%): 71.0\n",
      "\n",
      " SEGMENTACIÓN DEL CATÁLOGO\n",
      "    Segmento  Canciones  % del catálogo\n",
      "      🔴 Bajo        499            25.0\n",
      "🟡 Medio-Bajo        540            27.1\n",
